{
  "id": "dhamma-gun",
  "title": "တရားဂုဏ်တော် ၆ ပါး",
  "type": "morning",
  "content": [
    {
      "id": "heading-1",
      "order": 1,
      "burmese": "တရားဂုဏ်တော် ၆ ပါး",
      "translation": "The Six Virtues of the Dhamma",
      "type": "heading"
    },
    {
      "id": "verse-1",
      "order": 2,
      "burmese": "သွာက္ခာတော ဘဂဝတာ ဓမ္မော",
      "romanization": "Svākkhāto bhagavatā dhammo",
      "burmeseRomanization": "သွာက္ခာတော ဘဂဝတာ ဓမ္မော",
      "translation": "The Dhamma is well-proclaimed by the Blessed One",
      "type": "verse",
      "notes": "မြတ်စွာဘုရားသည် တရားတော်ကို ကောင်းစွာ ဟောကြားတော်မူ၏"
    },
    {
      "id": "verse-2",
      "order": 3,
      "burmese": "သန္ဒိဋ္ဌိကော",
      "romanization": "Sandiṭṭhiko",
      "burmeseRomanization": "သန်ဒိဋ္ဌိကော",
      "translation": "Visible here and now",
      "type": "verse",
      "notes": "ကိုယ်တိုင် မျက်မှောက်ပြု၍ သိမြင်နိုင်သော တရားတော် ဖြစ်ပါ၏"
    },
    {
      "id": "verse-3",
      "order": 4,
      "burmese": "အကာလိကော",
      "romanization": "Akāliko",
      "burmeseRomanization": "အကာလိကော",
      "translation": "Timeless",
      "type": "verse",
      "notes": "အချိန်မရွေး အကျိုးပေးနိုင်သော တရားတော် ဖြစ်ပါ၏"
    },
    {
      "id": "verse-4",
      "order": 5,
      "burmese": "ဧဟိပဿိကော",
      "romanization": "Ehipassiko",
      "burmeseRomanization": "ဧဟိပဿိကော",
      "translation": "Inviting one to come and see",
      "type": "verse",
      "notes": "လာကြ ကြည့်ကြဟု ဖိတ်ခေါ်ထိုက်သော တရားတော် ဖြစ်ပါ၏"
    },
    {
      "id": "verse-5",
      "order": 6,
      "burmese": "ဩပနယိကော",
      "romanization": "Opanayiko",
      "burmeseRomanization": "ဩပနယိကော",
      "translation": "Leading onwards",
      "type": "verse",
      "notes": "မိမိစိတ်တွင် ဆောင်ယူထားသင့်သော တရားတော် ဖြစ်ပါ၏"
    },
    {
      "id": "verse-6",
      "order": 7,
      "burmese": "ပစ္စတ္တံ ဝေဒိတဗ္ဗော ဝိညူဟီ'တိ။",
      "romanization": "Paccattaṃ veditabbo viññūhīti",
      "burmeseRomanization": "ပစ္စတ္တံ ဝေဒိတဗ္ဗော ဝိညူဟီတိ။",
      "translation": "To be personally experienced by the wise",
      "type": "verse",
      "notes": "ပညာရှိတို့သာ ကိုယ်တိုင်သိမြင် ခံစားနိုင်သော တရားတော် ဖြစ်ပါ၏"
    }
  ],
  "counterConfig": {
    "enabled": true,
    "defaultCount": 1
  },
  "metadata": {
    "author": "Traditional Myanmar Buddhist Chanting",
    "source": "Theravada Buddhist Tradition",
    "difficulty": "beginner",
    "tags": ["daily", "dhamma", "virtues"]
  }
}
