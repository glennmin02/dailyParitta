{
  "id": "sangha-gun",
  "title": "သံဃာဂုဏ်တော် ၉ ပါး",
  "type": "morning",
  "content": [
    {
      "id": "heading-1",
      "order": 1,
      "burmese": "သံဃာဂုဏ်တော် ၉ ပါး",
      "romanization": "Sangha Gon Daw Kou Par",
      "translation": "The Nine Virtues of the Sangha",
      "type": "heading"
    },
    {
      "id": "verse-1",
      "order": 2,
      "burmese": "သုပ္ပဋိပန္နော ဘဂဝတော သာဝကသံဃော",
      "romanization": "Suppaṭipanno bhagavato sāvakasaṅgho",
      "translation": "The Sangha of the Blessed One's disciples has practiced well",
      "type": "verse"
    },
    {
      "id": "verse-2",
      "order": 3,
      "burmese": "ဥဇုပ္ပဋိပန္နော ဘဂဝတော သာဝကသံဃော",
      "romanization": "Ujuppaṭipanno bhagavato sāvakasaṅgho",
      "translation": "Has practiced straightly",
      "type": "verse"
    },
    {
      "id": "verse-3",
      "order": 4,
      "burmese": "ညာယပ္ပဋိပန္နော ဘဂဝတော သာဝကသံဃော",
      "romanization": "Ñāyappaṭipanno bhagavato sāvakasaṅgho",
      "translation": "Has practiced methodically",
      "type": "verse"
    },
    {
      "id": "verse-4",
      "order": 5,
      "burmese": "သာမီစိပ္ပဋိပန္နော ဘဂဝတော သာဝကသံဃော။",
      "romanization": "Sāmīcippaṭipanno bhagavato sāvakasaṅgho",
      "translation": "Has practiced masterfully",
      "type": "verse"
    },
    {
      "id": "verse-5",
      "order": 6,
      "burmese": "ယဒိဒံ — စတ္တာရိ ပုရိသယုဂါနိ အဋ္ဌ ပုရိသပုဂ္ဂလာ။ ဧသ ဘဂဝတော သာဝကသံဃော —",
      "romanization": "Yadidaṃ cattāri purisayugāni aṭṭha purisapuggalā. Esa bhagavato sāvakasaṅgho",
      "translation": "The four pairs of persons, the eight types of individuals. This Sangha of the Blessed One's disciples",
      "type": "verse"
    },
    {
      "id": "verse-6",
      "order": 7,
      "burmese": "အာဟုနေယျော",
      "romanization": "Āhuneyyo",
      "translation": "Is worthy of gifts",
      "type": "verse"
    },
    {
      "id": "verse-7",
      "order": 8,
      "burmese": "ပါဟုနေယျော",
      "romanization": "Pāhuneyyo",
      "translation": "Worthy of hospitality",
      "type": "verse"
    },
    {
      "id": "verse-8",
      "order": 9,
      "burmese": "ဒက္ခိဏေယျော",
      "romanization": "Dakkhiṇeyyo",
      "translation": "Worthy of offerings",
      "type": "verse"
    },
    {
      "id": "verse-9",
      "order": 10,
      "burmese": "အဉ္ဇလိကရဏီယော",
      "romanization": "Añjalikaraṇīyo",
      "translation": "Worthy of reverential salutation",
      "type": "verse"
    },
    {
      "id": "verse-10",
      "order": 11,
      "burmese": "အနုတ္တရံ ပုညက္ခေတ္တံ လောကဿာ'တိ။",
      "romanization": "Anuttaraṃ puññakkhettaṃ lokassāti",
      "translation": "The incomparable field of merit for the world",
      "type": "verse"
    }
  ],
  "counterConfig": {
    "enabled": true,
    "defaultCount": 1
  },
  "metadata": {
    "author": "Traditional Myanmar Buddhist Chanting",
    "source": "Theravada Buddhist Tradition",
    "difficulty": "beginner",
    "tags": ["daily", "sangha", "virtues"]
  }
}
